
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

model User {
  id       String  @id @default(auto()) @map("_id") @db.ObjectId
  name     String
  email    String  @unique
  password String?

  image      String?
  provider   String?
  isVerified Boolean @default(false)

  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  emailVerified Boolean   @default(false)

  sessions      Session[]
  accounts      Account[]
  analyses      Analysis[]
  histories     History[]
  savedReports  SavedReport[]
  settings      Settings?
  notifications Notification[]

  @@map("user")
}

model Session {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  expiresAt DateTime
  token     String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  ipAddress String?
  userAgent String?
  userId    String   @db.ObjectId
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("session")
}

model Account {
  id                    String    @id @default(auto()) @map("_id") @db.ObjectId
  accountId             String
  providerId            String
  userId                String    @db.ObjectId
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  @@index([userId])
  @@map("account")
}

model Verification {
  id         String   @id @default(auto()) @map("_id") @db.ObjectId
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([identifier])
  @@map("verification")
}

model Video {
  id            String     @id @default(auto()) @map("_id") @db.ObjectId
  youtubeId     String     @unique
  title         String
  description   String?
  channelTitle  String?
  thumbnail     String?
  publishedAt   DateTime?
  duration      String?
  views         Int        @default(0)
  likes         Int        @default(0)
  comments      Int        @default(0)
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt
  analyses      Analysis[]
  commentsData  Comment[]
  histories     History[]

  @@map("video")
}

model Comment {
  id              String    @id @default(auto()) @map("_id") @db.ObjectId
  videoId         String    @db.ObjectId
  video           Video     @relation(fields: [videoId], references: [id], onDelete: Cascade)
  analysisId      String?   @db.ObjectId
  analysis        Analysis? @relation(fields: [analysisId], references: [id], onDelete: SetNull)
  author          String?
  text            String
  sentiment       String?
  category        String?
  language        String?
  likeCount       Int       @default(0)
  publishedAt     DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@index([videoId])
  @@index([analysisId])
  @@map("comment")
}

model Analysis {
  id                String        @id @default(auto()) @map("_id") @db.ObjectId
  userId            String        @db.ObjectId
  user              User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  videoId           String        @db.ObjectId
  video             Video         @relation(fields: [videoId], references: [id], onDelete: Cascade)
  title             String?
  summary           String?
  overallSentiment  String?
  totalComments     Int           @default(0)
  analyzedChunks    Int           @default(0)
  status            String        @default("completed")
  isBookmarked      Boolean       @default(false)
  aiMetadata        Json?
  keywords          Json?
  featureRequests   Json?
  bugReports        Json?
  questions         Json?
  complaints        Json?
  spam              Json?
  recommendations   Json?
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt
  comments          Comment[]
  categories        Category[]
  histories         History[]
  savedReports      SavedReport[]
  notifications     Notification[]

  @@index([userId])
  @@index([videoId])
  @@map("analysis")
}

model Category {
  id          String    @id @default(auto()) @map("_id") @db.ObjectId
  analysisId  String    @db.ObjectId
  analysis    Analysis  @relation(fields: [analysisId], references: [id], onDelete: Cascade)
  name        String
  count       Int       @default(0)
  summary     String?
  sampleComments Json?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([analysisId])
  @@map("category")
}

model History {
  id          String    @id @default(auto()) @map("_id") @db.ObjectId
  userId      String    @db.ObjectId
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  analysisId  String    @db.ObjectId
  analysis    Analysis  @relation(fields: [analysisId], references: [id], onDelete: Cascade)
  videoId     String?   @db.ObjectId
  video       Video?    @relation(fields: [videoId], references: [id], onDelete: SetNull)
  action      String    @default("created")
  createdAt   DateTime  @default(now())

  @@index([userId])
  @@index([analysisId])
  @@map("history")
}

model SavedReport {
  id          String    @id @default(auto()) @map("_id") @db.ObjectId
  userId      String    @db.ObjectId
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  analysisId  String    @db.ObjectId
  analysis    Analysis  @relation(fields: [analysisId], references: [id], onDelete: Cascade)
  name        String?
  createdAt   DateTime  @default(now())

  @@index([userId])
  @@index([analysisId])
  @@map("saved_report")
}

model Settings {
  id                  String   @id @default(auto()) @map("_id") @db.ObjectId
  userId              String   @unique @db.ObjectId
  user                User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  theme               String   @default("dark")
  notifications       Boolean  @default(true)
  emailNotifications  Boolean  @default(true)
  aiPreferences       Json?
  exportPreferences   Json?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  @@map("settings")
}

model Notification {
  id          String    @id @default(auto()) @map("_id") @db.ObjectId
  userId      String    @db.ObjectId
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  analysisId  String?   @db.ObjectId
  analysis    Analysis? @relation(fields: [analysisId], references: [id], onDelete: SetNull)
  title       String
  message     String
  isRead      Boolean   @default(false)
  createdAt   DateTime  @default(now())

  @@index([userId])
  @@index([analysisId])
  @@map("notification")
}
